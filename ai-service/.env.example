# ─── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/estorefont_db?schema=public
MONGODB_DB_NAME=ai_ecommerce_db

# ─── Ollama (runs locally) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Google Gemini ───────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ─── Server ──────────────────────────────────
PORT=8000

# ─── CORS ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
